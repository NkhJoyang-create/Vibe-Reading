# Lexis Reader API Credentials and Environment Settings
# Copy this file to '.env' and fill in your keys to use personal cloud-hosted API backends.

# 1. Gemini AI API Key (Required for smart dictionary lookup and markdown semantic parsing)
# Get your API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=

# 2. DeepSeek API Key (Optional fallback layer for custom paragraph translations)
# Get your API key from DeepSeek: https://platform.deepseek.com/
DEEPSEEK_API_KEY=
